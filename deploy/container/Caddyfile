# Caddyfile — single-origin front for the CareIN stack (local compose + Azure).
#
# One origin serves BOTH the built SPA and the API: Caddy file-serves the static
# dist for page routes and reverse-proxies /api/*, /auth/* and /socket.io/* to
# the backend. Single origin => no CORS, and the SPA's relative "/api" base
# (VITE_API_URL=/api) just works.
#
# The upstream is parameterized so the SAME file works in both environments:
#   - LOCAL docker compose: default `backend:5403` (the compose service, plain HTTP)
#   - AZURE Container Apps:  BACKEND_ORIGIN set to the backend's INTERNAL ingress
#                            FQDN, e.g. https://ca-carein-backend.internal.<env-domain>
#
# Caddy listens on :8088 over plain HTTP in both cases; TLS is terminated by the
# platform in front of it (Caddy locally is the dev edge; Azure Container Apps
# external ingress + managed cert terminates TLS for staging.carein.ai).

:8088 {
	# API routes -> backend.
	handle /api/* {
		reverse_proxy {$BACKEND_ORIGIN:backend:5403}
	}

	# Entra SSO routes (login / callback / logout / me) -> same backend.
	handle /auth/* {
		reverse_proxy {$BACKEND_ORIGIN:backend:5403}
	}

	# Socket.IO (live calls / transcripts). Caddy upgrades WebSockets itself.
	handle /socket.io/* {
		reverse_proxy {$BACKEND_ORIGIN:backend:5403}
	}

	# Everything else: the built SPA with history-API (client-route) fallback.
	handle {
		root * /srv
		encode zstd gzip
		try_files {path} /index.html
		file_server
	}
}
