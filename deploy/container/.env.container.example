# ===========================================================================
# CareIN container-parity environment (DEV values — NO real secrets).
# Copy to `.env.container` (gitignored) and adjust if your local creds differ.
# ===========================================================================
#
# These are LOCAL-ONLY throwaway dev values. In Azure, NONE of this lives in a
# file: a managed identity on the Container App fetches DB URLs + API keys from
# Key Vault at startup (config/secrets.js, NODE_ENV=production). This env file is
# the dev stand-in for that.

# --- Core -------------------------------------------------------------------
NODE_ENV=development
PORT=5403
# Single-origin front (Caddy :8088) => CORS is not strictly needed, but keep the
# origin allow-listed so direct/browser access works during debugging.
CORS_ORIGIN=http://localhost:8088,http://localhost:5403

# Shared bearer token for /api/* (any non-empty dev value works locally).
DASHBOARD_API_TOKEN=dev-parity-token-change-me
# Session signing key for the Entra SSO cookie. Set so we can mint a dev session
# cookie to prove the authenticated tenant-context path end to end.
DASHBOARD_SESSION_SECRET=dev-parity-session-secret-change-me

# ---------------------------------------------------------------------------
# Postgres — the CONTAINER NETWORKING GOTCHA.
# ---------------------------------------------------------------------------
# `localhost` inside a container is the CONTAINER, not your machine. The host
# Postgres (carein-local-pg) publishes 5432 on the host as 55433, so from inside
# the backend container we reach it via `host.docker.internal:55433`
# (docker-compose maps that name to the host via extra_hosts: host-gateway).
#
#   WRONG (inside a container):  postgres://...@localhost:55433/...
#   RIGHT:                       postgres://...@host.docker.internal:55433/...
#
# carein_owner / carein_owner_devpw are the documented dev throwaway creds from
# dev/local/docker-compose.yml. (Prod uses a least-privilege role via Key Vault.)
CONTROL_DB_URL=postgres://carein_owner:carein_owner_devpw@host.docker.internal:55433/carein_control

# Per-tenant data-plane DB. The control row tenant_database.kv_conn_secret is
# 'tenant-carein-db-url'; in dev that resolves to the env var TENANT_CAREIN_DB_URL
# (kebab -> SCREAMING_SNAKE). Same host.docker.internal rule applies.
TENANT_CAREIN_DB_URL=postgres://carein_owner:carein_owner_devpw@host.docker.internal:55433/carein_t_carein

# ---------------------------------------------------------------------------
# Open Dental — API mode (public URL, NO container gotcha).
# ---------------------------------------------------------------------------
OPENDENTAL_INTEGRATION_MODE=api
OPENDENTAL_API_BASE_URL=https://api.opendental.com/api/v1
# Dev placeholders — leave blank locally; OD calls simply won't be made.
OPENDENTAL_DEVELOPER_KEY=
OPENDENTAL_CUSTOMER_KEY=
# NOTE: if you ever point at a LOCAL on-prem OD connector, it would be on the
# host too — use host.docker.internal there as well, e.g.
#   OD_CONNECTOR_URL=http://host.docker.internal:4000

# ---------------------------------------------------------------------------
# External services — left blank for parity (startup sync no-ops + logs a warn,
# which is non-fatal by design). Fill with real keys only for a live test.
# ---------------------------------------------------------------------------
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
WEBHOOK_VERIFY_DISABLED=true
RETELL_TOOLS_ENABLED=false
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
MANGO_USERNAME=
MANGO_PASSWORD=
