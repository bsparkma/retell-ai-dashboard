# CareIn legacy frontend (CRA) — example environment file.
# Copy to frontend/.env and fill in.

# Dev server port
PORT=3004

# Backend API base URL (no trailing slash). Default is localhost:5001/api.
REACT_APP_API_URL=http://localhost:5001/api

# Bearer token for the backend dashboard auth middleware.
# Must match DASHBOARD_API_TOKEN on the backend.
# Required when the backend runs in production.
REACT_APP_DASHBOARD_API_TOKEN=
