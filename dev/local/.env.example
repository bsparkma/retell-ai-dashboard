# dev/local/.env — OPTIONAL overrides for the LOCAL Postgres stack.
# Copy to dev/local/.env (already gitignored) only if you want to change the
# defaults. These are LOCAL-ONLY throwaway dev credentials for a localhost
# container — they are NOT secrets and are NOT the backend's .env.
#
# If you change CAREIN_APP_PASSWORD here, use the SAME value in the
# carein_app portion of TENANT_CAREIN_DB_URL in backend/.env.
# These take effect only on FIRST `docker compose up` (fresh volume); after that
# the roles/passwords are baked into the volume until `docker compose down -v`.

CAREIN_OWNER_PASSWORD=carein_owner_devpw
CAREIN_APP_PASSWORD=carein_app_devpw
CAREIN_PG_HOST_PORT=55433
