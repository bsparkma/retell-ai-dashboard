# CareIn Backend — example environment file.
# Copy to backend/.env and fill in real values. Never commit backend/.env.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
PORT=5001
NODE_ENV=development
# Comma-separated list of CORS origins for the dashboard front-ends.
CORS_ORIGIN=http://localhost:3000,http://localhost:3005

# Bearer token required by the dashboard auth middleware.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the SAME value as VITE_DASHBOARD_API_TOKEN in new-dashboard/.env
# (and REACT_APP_DASHBOARD_API_TOKEN in frontend/.env if you use the legacy UI).
# Required in production — server returns 503 if unset.
DASHBOARD_API_TOKEN=

# ---------------------------------------------------------------------------
# Retell AI
# ---------------------------------------------------------------------------
RETELL_API_KEY=<set-me>
# Retell webhook signing secret (from Retell dashboard).
# Used by backend/routes/webhooks.js to verify incoming webhooks.
RETELL_WEBHOOK_SECRET=<set-me>
# Set to "true" only for local debugging. Logs a loud warning every request.
WEBHOOK_VERIFY_DISABLED=false

# Retell custom-function (tool) endpoints under /api/retell-tools/*.
# These let the live agent look up patients, find slots, book, and create
# callbacks. Disabled by default — flip to "true" only after you have
# pasted matching tool definitions into the Retell agent dashboard
# (see docs/retell-tools.md).
RETELL_TOOLS_ENABLED=false

# ---------------------------------------------------------------------------
# Mango Voice (call recording portal scrape)
# ---------------------------------------------------------------------------
MANGO_PORTAL_URL=https://admin.mangovoice.com
MANGO_USERNAME=<set-me>
MANGO_PASSWORD=<set-me>
MANGO_PBX_NAME=<set-me>
MANGO_SYNC_SCHEDULE=15 * * * *
MANGO_MAX_RECORDINGS_PER_SYNC=10

# ---------------------------------------------------------------------------
# AI services
# ---------------------------------------------------------------------------
# Transcription: Azure AI Speech (Fast Transcription, BAA-covered). Managed identity is
# preferred in staging/prod (no key needed); set AUTH_MODE=api_key + key for local dev.
# Deepgram is NOT used (no BAA) and must never transcribe real recording audio.
AZURE_SPEECH_ENDPOINT=https://spch-carein-staging.cognitiveservices.azure.com
# AZURE_SPEECH_REGION=southcentralus            # alternative to ENDPOINT
AZURE_SPEECH_AUTH_MODE=managed_identity          # managed_identity | api_key
# AZURE_SPEECH_API_KEY=<set-me>                  # only when AUTH_MODE=api_key (from Key Vault: azure-speech-key)
# AZURE_SPEECH_LOCALES=en-US
# AZURE_SPEECH_MAX_SPEAKERS=2
OPENAI_API_KEY=<set-me>

# ---------------------------------------------------------------------------
# Open Dental
# ---------------------------------------------------------------------------
# Use API mode for cloud Open Dental, or DB mode for direct MySQL.
OPENDENTAL_INTEGRATION_MODE=api

# API mode
OPENDENTAL_API_BASE_URL=https://api.opendental.com/api/v1
OPENDENTAL_DEVELOPER_KEY=<set-me>
OPENDENTAL_CUSTOMER_KEY=<set-me>

# DB mode (direct MySQL)
# OPENDENTAL_DB_HOST=
# OPENDENTAL_DB_PORT=3306
# OPENDENTAL_DB_USER=
# OPENDENTAL_DB_PASSWORD=
# OPENDENTAL_DB_NAME=opendental

# Optional: UNC path to OpenDentImages share for chart photos.
OPENDENTAL_IMAGES_PATH=

# ---------------------------------------------------------------------------
# Control plane (carein_control Postgres)
# ---------------------------------------------------------------------------
# Connection string for the control-plane database. Migrations are run with
# node-pg-migrate via:  npm run migrate:up
# In dev this comes from here; in prod it is fetched from Key Vault secret
# `control-db-url`. Include sslmode=require for Azure Postgres.
#   postgres://user:pass@host:5432/carein_control?sslmode=require
CONTROL_DB_URL=

# Per-tenant data-plane DB connection strings (one per tenant).
# The secret NAME is stored in carein_control.tenant_database.kv_conn_secret;
# the VALUE is resolved at runtime — in dev from the env var derived from that
# name (kebab -> SCREAMING_SNAKE), in prod from the Key Vault secret of that name.
# CareIN tenant #1 uses secret name 'tenant-carein-db-url' -> env TENANT_CAREIN_DB_URL.
#   postgres://user:pass@host:5432/carein_t_carein?sslmode=require
TENANT_CAREIN_DB_URL=
