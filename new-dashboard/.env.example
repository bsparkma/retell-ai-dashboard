# CareIn Dashboard — point to your existing backend
# Copy to .env and set values as needed.
#
# The dashboard uses this backend for:
# - Unified calls (Retell AI + Mango Voice)
# - Live calls (Socket.IO on same host)
# - Callbacks, Open Dental calendar/appointments, agents, health
#
# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5001/api

# Default clinic number shown in the booking wizard (used when no appointment data is loaded)
VITE_CLINIC_NUM=1

# ---------------------------------------------------------------------------
# CareIN Scheduling Engine (server/scheduling + server/pms)
# Set these when running the scheduling server (pnpm dev:server)
# ---------------------------------------------------------------------------

# PMS type — OPEN_DENTAL | DENTRIX | EAGLESOFT
PMS_TYPE=OPEN_DENTAL

# Open Dental MySQL connection (only needed when PMS_TYPE=OPEN_DENTAL)
OD_HOST=localhost
OD_PORT=3306
OD_DATABASE=opendental
OD_USER=root
OD_PASSWORD=
OD_CLINIC_NUM=1

# NexHealth integration (only needed when PMS_TYPE=DENTRIX or EAGLESOFT)
# NEXHEALTH_API_KEY=
# NEXHEALTH_PRACTICE_ID=

# Port for the scheduling Express server (default: 3000)
# The Vite dev server proxies /api/scheduling/* to this port
SCHEDULING_SERVER_PORT=3000
