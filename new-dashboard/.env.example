# CareIn Dashboard — point to your existing backend
# Copy to .env and set values as needed.
#
# The dashboard uses this backend for:
# - Unified calls (Retell AI + Mango Voice)
# - Live calls (Socket.IO on same host)
# - Callbacks, Open Dental calendar/appointments, agents, health
#
# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Bearer token sent as `Authorization: Bearer <token>` on every API request.
# Must match DASHBOARD_API_TOKEN on the backend (see backend/.env).
# Required in production. In dev, leave blank to skip auth.
VITE_DASHBOARD_API_TOKEN=

# ---------------------------------------------------------------------------
# CareIN server (server/index.ts, default port 3000)
# ---------------------------------------------------------------------------

# Retell API key — used to verify the x-retell-signature header on incoming
# webhooks via Retell.verify(). Get this from the Retell dashboard.
# If unset: signature verification is disabled and a warning is logged at startup.
# REQUIRED before receiving live traffic.
RETELL_API_KEY=

# CareIN client base URL (read by Vite; used by careInApi in api.ts).
# In dev the CareIN server runs on port 3000 alongside the existing backend (5000).
VITE_CAREIN_API_URL=http://localhost:3000/api

# Force seed data on every server restart (dev/demo only — do NOT set in production).
# When true: replaces any persisted calls.json with the 15 synthetic fixture calls.
# When unset or false: uses persisted data; seeds only if the store is empty.
# USE_SEED_DATA=true
